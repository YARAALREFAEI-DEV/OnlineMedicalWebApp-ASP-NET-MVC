@model Next2OnlineMedicalApp.Models.Appointment

@{
    ViewData["Title"] = "Appointment Details";
}

<h1>@ViewData["Title"]</h1>

<div>
    <h4>Appointment</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AppointmentId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AppointmentId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.DoctorId)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.DoctorId)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.AppointmentDate)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.AppointmentDate)
        </dd>
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.Status)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.Status)
        </dd>
    </dl>
</div>

<div>
    <a class="btn btn-primary" asp-area="PatientArea" asp-controller="Appointments" asp-action="Edit" asp-route-id="@Model.AppointmentId">Edit</a>
    <a class="btn btn-secondary" asp-area="PatientArea" asp-controller="Appointments" asp-action="Index">Back to List</a>
</div>
