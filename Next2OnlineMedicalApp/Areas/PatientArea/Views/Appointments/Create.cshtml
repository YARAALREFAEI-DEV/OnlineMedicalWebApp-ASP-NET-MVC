@model Next2OnlineMedicalApp.Models.Appointment

@{
    ViewData["Title"] = "Create Appointment";
}

<h1>@ViewData["Title"]</h1>

<h4>Appointment</h4>
<hr />
<form asp-action="Create">
    <div class="form-group">
        <label asp-for="DoctorId" class="control-label"></label>
        <select asp-for="DoctorId" class="form-control" asp-items="@ViewBag.DoctorList">
            <option value="">Select a Doctor</option>
        </select>
        <span asp-validation-for="DoctorId" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="AppointmentDate" class="control-label"></label>
        <input asp-for="AppointmentDate" class="form-control" />
        <span asp-validation-for="AppointmentDate" class="text-danger"></span>
    </div>
    <div class="form-group">
        <label asp-for="Status" class="control-label"></label>
        <input asp-for="Status" value="Confirmed" class="form-control"  readonly/>
        <span asp-validation-for="Status" class="text-danger"></span>
    </div>
    <div class="form-group">
        <input type="submit" value="Create" class="btn btn-primary" />
    </div>
</form>

<div>
    <a asp-area="PatientArea" asp-controller="Appointments" asp-action="Index">Back to List</a>
</div>
